{
  "name": "@koradio/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "build:packages": "pnpm --filter @koradio/contracts build && pnpm --filter @koradio/design-tokens build",
    "predev": "pnpm build:packages",
    "dev": "pnpm --parallel --filter @koradio/server --filter @koradio/web dev",
    "build": "pnpm build:packages && pnpm --filter @koradio/server build && pnpm --filter @koradio/web build",
    "start": "pnpm --filter @koradio/server start",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/component",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:coverage": "vitest run --coverage",
    "audit:security": "pnpm audit --audit-level high",
    "audit:licenses": "node scripts/security/audit-licenses.mjs",
    "audit:dependencies": "pnpm audit:security && pnpm audit:licenses",
    "package:macos": "node scripts/release/build-macos.mjs",
    "verify:package:macos": "node scripts/release/verify-macos-package.mjs",
    "verify:lifecycle:macos": "node scripts/release/verify-macos-lifecycle.mjs",
    "check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:contract && pnpm test:integration && pnpm test:component && pnpm test:coverage && pnpm build"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@fastify/websocket": "11.3.0",
    "@playwright/test": "1.61.1",
    "@koradio/contracts": "workspace:*",
    "@koradio/design-tokens": "workspace:*",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
