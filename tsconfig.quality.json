{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "jsx": "react-jsx",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  "include": [
    "*.config.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "references": [
    { "path": "./apps/server" },
    { "path": "./packages/contracts" },
    { "path": "./packages/design-tokens" }
  ]
}
